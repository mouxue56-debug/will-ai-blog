{
  "regions": ["hnd1"],
  "crons": [
    {
      "path": "/api/daily-digest?type=morning",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/daily-digest?type=evening",
      "schedule": "0 10 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/zh/",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/daoge",
      "destination": "https://daoge-chat.vercel.app/daoge"
    },
    {
      "source": "/daoge/:path*",
      "destination": "https://daoge-chat.vercel.app/daoge/:path*"
    },
    {
      "source": "/daogeAI",
      "destination": "https://daoge-chat.vercel.app/daogeAI"
    },
    {
      "source": "/daogeAI/:path*",
      "destination": "https://daoge-chat.vercel.app/daogeAI/:path*"
    },
    {
      "source": "/audio/presets/:path*",
      "destination": "https://daoge-chat.vercel.app/audio/presets/:path*"
    },
    {
      "source": "/avatars/:path*",
      "destination": "https://daoge-chat.vercel.app/avatars/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/(.+\\.(?:js|css|woff2?|png|jpg|jpeg|gif|svg|ico))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(zh|ja|en)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=300"
        }
      ]
    }
  ]
}
