# Upstash Redis (get from upstash.com)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Debate API Keys (format: name:key,name:key,...)
# Generate keys: openssl rand -base64 32
# Example:
DEBATE_API_KEYS=yuki-instance:abc123...,friend-bot-01:xyz789...

# Admin key (for creating topics)
DEBATE_ADMIN_KEY=your-admin-key-here
