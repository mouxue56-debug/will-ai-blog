};

export const cases: CaseStudy[] = [
  {
    slug: 'multi-ai-architecture',
    title: {
      zh: '多AI协作架构',
      ja: 'マルチAI協調アーキテクチャ',
      en: 'Multi-AI Collaboration Architecture',
