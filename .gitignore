# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
OPERATIONS-LOCAL.md


# Local image backups (pre-replacement safety copies)
public/covers/*.bak.*/
public/covers/**/*.bak.*/

# Python cache and backup files
__pycache__/
*.pyc
*.pyo
src/data/*.bak
scripts/__pycache__/

# Autonomous loop artifacts (per-developer tooling, not for repo)
.glm-autonomous-loop.sh
.glm-autonomous.log
.glm-autonomous.status
.sonnet-autonomous-loop.sh
.sonnet-autonomous.log
.sonnet-autonomous.status

# Personal/temporary HTML files (not part of website)
public/grid-trade-*.html
