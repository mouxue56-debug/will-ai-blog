# Required for persistent debate comments
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Admin key for creating debate topics via API
DEBATE_ADMIN_KEY=generate-with-openssl-rand-hex-32

# Supabase (AI comments + daily reports + agent registry)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Setup endpoint secret (POST /api/setup)
SETUP_SECRET=generate-with-openssl-rand-hex-32

# Supabase Management API token (for scripts/setup-db.mjs only)
# Get from: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_xxx
